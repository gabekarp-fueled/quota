# =============================================================================
# Quota Agent Framework — Environment Variables
# Copy this file to .env and fill in your values.
# =============================================================================

# --- Required ---

# PostgreSQL connection string (async driver)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/quota

# Anthropic Claude API key
ANTHROPIC_API_KEY=sk-ant-...

# Dashboard authentication
# Password to log in to the web UI
DASHBOARD_PASSWORD=change-me-in-production
# Secret for JWT token signing (generate with: openssl rand -hex 32)
JWT_SECRET=change-me-in-production

# --- Email (Gmail OAuth2 + IMAP) ---

# Gmail address used to send and receive emails
GMAIL_ADDRESS=you@yourdomain.com

# Path to your Gmail OAuth2 token file (created by oauth_setup.py)
GMAIL_TOKEN_PATH=gmail_token.json

# SMTP settings for sending
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# IMAP settings for inbox monitoring
IMAP_HOST=imap.gmail.com
IMAP_PORT=993

# --- Attio CRM ---

# Attio API key (from app.attio.com → Settings → API)
ATTIO_API_KEY=

# Your Attio workspace slug (visible in the URL: app.attio.com/{slug})
ATTIO_WORKSPACE_SLUG=

# --- Apollo.io (contact sourcing) ---

# Apollo API key for prospect research and enrichment
APOLLO_API_KEY=

# --- FullEnrich (email verification, optional) ---

FULLENRICH_API_KEY=

# --- Slack (optional) ---

# Slack bot token (xoxb-...) for sending notifications and approval messages
SLACK_BOT_TOKEN=

# Channel ID where CRO posts daily digests and approval requests
SLACK_CHANNEL_ID=

# --- Scheduler ---

# Timezone for scheduled tasks (default: America/Los_Angeles)
SCHEDULER_TZ=America/Los_Angeles

# Hour (0-23) to run the CRO daily review (default: 7 = 7am)
CRO_HOUR=7

# Hour (0-23) to send the daily digest (default: 8 = 8am)
DIGEST_HOUR=8

# Hour (0-23) to run follow-up sequence (default: 10 = 10am)
FOLLOWUP_HOUR=10

# Interval in minutes to poll inbox (default: 15)
INBOX_INTERVAL_MINUTES=15
